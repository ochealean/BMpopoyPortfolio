TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_token
SUPERVISOR_EMAIL=admin@example.com
SUPERVISOR_PASSWORD=replace-with-strong-password
# Optional alternative: compare against SHA-256 hash instead of plain text password
# SUPERVISOR_PASSWORD_HASH=replace_with_sha256_hash
ADMIN_JWT_SECRET=replace-with-long-random-secret
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
